# Server
PORT=3000
NODE_ENV=development

# Postgres persistence
# Neon pooled connection string example:
# postgresql://user:password@ep-xxxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# Optional SSL override for local Postgres:
# auto | true | false
DATABASE_SSL=auto

# Admin panel auth (required for /admin)
# Change these in Render Environment Variables before going live.
ADMIN_PASSWORD=change_this_password
ADMIN_SESSION_SECRET=change_this_to_a_long_random_secret

# Contact delivery target (your inbox)
CONTACT_TO_EMAIL=you@example.com

# Optional custom sender; defaults to SMTP_USER if omitted
CONTACT_FROM_EMAIL=portfolio-bot@example.com

# SMTP (required if you want real email delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Python agent demo page
PYTHON_EXECUTABLE=
AGENT_TIMEOUT_MS=45000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
